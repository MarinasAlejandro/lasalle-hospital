# Plantilla de variables de entorno.
# Todos los servicios ya tienen defaults equivalentes en docker-compose.yml,
# por lo que NO hace falta crear un .env para arrancar. Copia este fichero
# a .env solo si necesitas personalizar puertos o credenciales:
#   cp .env.example .env

# MongoDB
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DB=hospital

# MinIO
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET_RADIOGRAPHIES=radiographies
MINIO_BUCKET_RAW_BACKUPS=raw-backups

# Pipeline
LOG_LEVEL=INFO
SPARK_APP_NAME=hospital-pipeline
SPARK_MASTER=local[*]

# API (futuro)
API_PORT=8000
